{
  "name": "kimi-plugin-cc",
  "version": "0.1.3",
  "private": true,
  "description": "Planning bundle and repo skeleton for a Codex-grade Claude Code plugin for Kimi.",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "check": "bun run build && bunx tsc --noEmit && bun test && git diff --exit-code -- dist",
    "build": "rm -rf dist && bunx tsc -p tsconfig.build.json",
    "companion": "node --import tsx runtime/companion.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/shell-quote": "^1.7.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "shell-quote": "^1.8.3"
  }
}
